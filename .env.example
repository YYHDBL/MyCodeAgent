# MyCodeAgent core configuration
# Copy to .env and replace the LLM placeholders.

# OpenAI-compatible LLM connection
LLM_PROVIDER=siliconflow
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_ID=Pro/moonshotai/Kimi-K2.5

# Common runtime settings
# TEMPERATURE=0.7
# MAX_TOKENS=
# CONTEXT_WINDOW=128000
# COMPRESSION_THRESHOLD=0.8
# MIN_RETAIN_ROUNDS=10
# LOG_LEVEL=INFO
# DEBUG=false

# Optional capabilities (all are disabled unless explicitly enabled, except
# local JSONL tracing and lazy skills).  These correspond directly to Config.
# ENABLE_MCP=true
# ENABLE_VERIFICATION_AGENT=true
# ENABLE_SKILLS=false
# SKILLS_REFRESH_ON_CALL=true
# ENABLE_TRACING=false
# TRACE_HTML_ENABLED=true
